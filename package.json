{
  "name": "sisteco-landing",
  "version": "2.0.0",
  "description": "Landing page para Sisteco - Infraestructura inteligente para ventas B2B",
  "scripts": {
    "start": "node server.cjs",
    "dev": "npx convex dev & node server.cjs",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy",
    "vercel-dev": "vercel dev",
    "build": "npx convex deploy --cmd 'echo build done'",
    "setup:plans": "node -r dotenv/config api/setup-dlocalgo-plans.js",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "convex": "^1.32.0",
    "opentype.js": "^1.3.4",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  }
}
