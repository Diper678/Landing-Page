{
  "version": 2,
  "buildCommand": "npx convex deploy --cmd 'echo build done'",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com https://app.cal.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.convex.cloud https://*.upstash.io https://api.resend.com https://app.cal.com; frame-src https://app.cal.com"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/soluciones", "destination": "/pages/soluciones.html" },
    { "source": "/como-funciona", "destination": "/pages/como-funciona.html" },
    { "source": "/integraciones", "destination": "/pages/integraciones.html" },
    { "source": "/dashboard", "destination": "/pages/dashboard.html" },
    { "source": "/precios", "destination": "/pages/precios.html" },
    { "source": "/sobre-nosotros", "destination": "/pages/sobre-nosotros.html" },
    { "source": "/blog", "destination": "/pages/blog.html" },
    { "source": "/api-docs", "destination": "/pages/api.html" },
    { "source": "/documentacion", "destination": "/pages/documentacion.html" },
    { "source": "/tutoriales", "destination": "/pages/tutoriales.html" },
    { "source": "/webinars", "destination": "/pages/webinars.html" },
    { "source": "/soporte", "destination": "/pages/soporte.html" },
    { "source": "/contacto", "destination": "/pages/contacto.html" },
    { "source": "/carreras", "destination": "/pages/carreras.html" },
    { "source": "/privacidad", "destination": "/pages/privacidad.html" },
    { "source": "/terminos", "destination": "/pages/terminos.html" },
    { "source": "/cookies", "destination": "/pages/cookies.html" },
    { "source": "/gdpr", "destination": "/pages/gdpr.html" },
    { "source": "/agendar-demo", "destination": "/pages/agendar-demo.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/send-drip",
      "schedule": "0 14 * * *"
    }
  ]
}
