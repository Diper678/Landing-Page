# ── Convex ──
# Obtener al ejecutar: npx convex dev
CONVEX_URL=https://your-project.convex.cloud

# ── Clerk (Auth Provider) ──
# Obtener desde: https://dashboard.clerk.com → API Keys / Integrations
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev

# ── App ──
SITE_URL=http://localhost:3000

# ── Resend (Email) ──
RESEND_API_KEY=re_...
FROM_EMAIL=Sisteco <noreply@onboarding.sisteco.cl>

# ── Upstash Redis (Rate Limiting — opcional) ──
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── n8n ──
N8N_WEBHOOK_URL=https://tu-instancia.n8n.cloud/webhook/sisteco-orchestration
N8N_AUTH_KEY=your_key

# ── Vercel Cron ──
CRON_SECRET=your_cron_secret

# ── Alertas internas (Discord) ──
# Webhook del canal donde llegan leads, contactos, pagos y señales de comportamiento.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# ── PostHog (analítica + behavior-alerts cron) ──
# Personal API key READ-ONLY (Settings > Personal API Keys) — no la project key pública.
POSTHOG_API_KEY=phx_...
POSTHOG_PROJECT_ID=12345

# ── Agendador ──
# Link de Google Calendar appointment schedule. También hay que pegarlo en js/consent.js (BOOKING_URL).
GOOGLE_CALENDAR_BOOKING_URL=https://calendar.app.google/xxxxx

# =============================================
# PASARELAS DE PAGO (post-pivote 2026-05-24)
# =============================================
# Sisteco usa:
#   - Flow.cl     → PRINCIPAL para clientes Chile (Webpay/OnePay/transferencia/tarjetas chilenas)
#   - dLocal Go   → FALLBACK para clientes LATAM (Colombia, Perú, Argentina) en USD
#   - Reveniu     → DEPRECADO 2026-05-24 (no se usa más; clientes legacy migran a Flow.cl en próximo ciclo)
# Planes activos (rename 2026-05-24): base · crecimiento · hablemos
# Planes deprecados (NO usar en código nuevo): junior · senior · manager (aliases legacy mantenidos por compat)

# ── Flow.cl (Chile — pasarela principal) ──
# Dashboard: https://www.flow.cl/app
# Documentación: https://www.flow.cl/docs/api.html
# IMPORTANT:
#   1. Las keys NUNCA van en código ni se comitean en git.
#   2. En producción se configuran como Vercel Env Vars marcadas "Sensitive".
#   3. Si una key se expone (chat, screenshot, repo público): rotarla INMEDIATAMENTE en Flow.cl.
FLOW_API_KEY=your_flow_api_key_here
FLOW_SECRET_KEY=your_flow_secret_key_here
FLOW_BASE_URL=https://sandbox.flow.cl/api
# Producción: https://www.flow.cl/api

# Flow.cl URLs de retorno (configuradas en panel Flow + en API calls)
FLOW_RETURN_URL=https://sisteco.cl/pago-exitoso
FLOW_CONFIRMATION_URL=https://sisteco.cl/api/flow-webhook
FLOW_FAILURE_URL=https://sisteco.cl/pago-fallido

# Flow.cl planes / commerceOrder IDs (1 link de pago por combinación plan × cadencia × descuento)
# Pricing autoritativo post-pivote: docs/handoffs/2026-05-24-modelo-cobro-y-entregables.md
#   - Base 20 UF/mes (~CLP 770.000 neto)
#   - Crecimiento CLP 1.200.000/mes (~USD 1.290 neto · incluye Meta Ads cap USD 5k/mes)
#   - Hablemos: cotización a medida
# Sobre los token=xxxxx: Felipe debe generar los links de pago reales en https://www.flow.cl/app
# y reemplazar acá. TODO Felipe: estos placeholders están pendientes desde antes del pivote.
FLOW_PLAN_BASE_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_BASE_ANUAL=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_CRECIMIENTO_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_CRECIMIENTO_ANUAL=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_HABLEMOS_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
# Aliases legacy (DEPRECADOS 2026-05-24 — mantener mientras existan clientes en planes viejos)
FLOW_PLAN_JUNIOR_TRIM1=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_JUNIOR_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_JUNIOR_ANUAL=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_SENIOR_TRIM1=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_SENIOR_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_SENIOR_ANUAL=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_MANAGER_TRIM1=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_MANAGER_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_MANAGER_ANUAL=https://www.flow.cl/btn.php?token=xxxxx

# ── dLocal Go (LATAM internacional) ──
# Dashboard: https://dashboard.dlocalgo.com (prod) / https://dashboard-sbx.dlocalgo.com (sandbox)
DLOCALGO_API_KEY=your_api_key_here
DLOCALGO_SECRET_KEY=your_secret_key_here
DLOCALGO_WEBHOOK_SECRET=your_webhook_secret_here
DLOCALGO_BASE_URL=https://api-sbx.dlocalgo.com/v1

# Precio público de entrada de LYD (2026-06-15): Plan Fundadores USD 500/mes.
# LYD NO se cobra por dLocal. TODO Felipe: pegar acá el LINK DE PAGO NUEVO de LYD
# (Flow.cl u otra pasarela). Hasta entonces el checkout de LYD queda pendiente.
LYD_PAYMENT_LINK=https://www.flow.cl/btn.php?token=xxxxx

# Plan IDs (nomenclatura nueva post-rename 2026-05-24)
DLOCALGO_PLAN_BASE_MONTHLY=plan_xxxxx
DLOCALGO_PLAN_BASE_ANNUAL=plan_xxxxx
DLOCALGO_PLAN_CRECIMIENTO_MONTHLY=plan_xxxxx
DLOCALGO_PLAN_CRECIMIENTO_ANNUAL=plan_xxxxx
DLOCALGO_PLAN_HABLEMOS_MONTHLY=plan_xxxxx
# Aliases legacy (mantenidos por compat con clientes activos; remover post-migración)
DLOCALGO_PLAN_JUNIOR_MONTHLY=plan_xxxxx
DLOCALGO_PLAN_JUNIOR_ANNUAL=plan_xxxxx
DLOCALGO_PLAN_SENIOR_MONTHLY=plan_xxxxx
DLOCALGO_PLAN_SENIOR_ANNUAL=plan_xxxxx
DLOCALGO_PLAN_MANAGER_MONTHLY=plan_xxxxx

# ── Reveniu (DEPRECADO 2026-05-24) ──
# NO se usa más. Reemplazado por Flow.cl como proveedor principal Chile.
# Clientes legacy con cobro activo en Reveniu se migran a Flow.cl en su próximo ciclo.
# Conservados como referencia histórica solamente.
# REVENIU_LINK_JUNIOR_MONTHLY=https://app.reveniu.com/checkout/xxxxx
# REVENIU_LINK_JUNIOR_ANNUAL=https://app.reveniu.com/checkout/xxxxx
# REVENIU_LINK_SENIOR_MONTHLY=https://app.reveniu.com/checkout/xxxxx
# REVENIU_LINK_SENIOR_ANNUAL=https://app.reveniu.com/checkout/xxxxx
# REVENIU_LINK_MANAGER_MONTHLY=https://app.reveniu.com/checkout/xxxxx

# =============================================
# CONFIGURACIÓN EN VERCEL (producción)
# =============================================
# 1. Vercel Dashboard → Tu Proyecto → Settings → Environment Variables
# 2. Agregar TODAS las variables de arriba
# 3. Marcar como "Sensitive":
#    - FLOW_API_KEY, FLOW_SECRET_KEY (pasarela principal Chile)
#    - DLOCALGO_SECRET_KEY, DLOCALGO_WEBHOOK_SECRET (fallback LATAM)
#    - CRON_SECRET, RESEND_API_KEY, N8N_AUTH_KEY
# 4. URLs producción:
#    - FLOW_BASE_URL → https://www.flow.cl/api
#    - DLOCALGO_BASE_URL → https://api.dlocalgo.com/v1
#    - SITE_URL → https://sisteco.cl
# 5. Política de rotación: rotar keys cada 90 días o si hay sospecha de exposición.
