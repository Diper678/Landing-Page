# ── Supabase ──
# Obtener desde: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ──
SITE_URL=http://localhost:3000

# ── dLocal Go (Opción B — integración API) ──
# Dashboard: https://dashboard.dlocalgo.com (prod) / https://dashboard-sbx.dlocalgo.com (sandbox)
# Paso 1: Crear cuenta → Paso 2: Integrations → API Integration → copiar keys
DLOCALGO_API_KEY=your_api_key_here
DLOCALGO_SECRET_KEY=your_secret_key_here
DLOCALGO_WEBHOOK_SECRET=your_webhook_secret_here
DLOCALGO_BASE_URL=https://api-sbx.dlocalgo.com/v1

# Plan IDs — crear en Dashboard → Subscriptions → Create Plan
# Ver .planning/PAYMENT_SETUP.md para montos y configuración de cada plan
DLOCALGO_PLAN_BASE_MONTHLY=plan_xxxxx
DLOCALGO_PLAN_BASE_ANNUAL=plan_xxxxx
DLOCALGO_PLAN_GROWTH_MONTHLY=plan_xxxxx
DLOCALGO_PLAN_GROWTH_ANNUAL=plan_xxxxx
DLOCALGO_PLAN_ENTERPRISE_MONTHLY=plan_xxxxx

# ── Reveniu (Opción A — quick start sin código) ──
# Dashboard: https://app.reveniu.com
# Crear planes en Reveniu → copiar los links de pago generados
REVENIU_LINK_BASE_MONTHLY=https://app.reveniu.com/checkout/xxxxx
REVENIU_LINK_BASE_ANNUAL=https://app.reveniu.com/checkout/xxxxx
REVENIU_LINK_GROWTH_MONTHLY=https://app.reveniu.com/checkout/xxxxx
REVENIU_LINK_GROWTH_ANNUAL=https://app.reveniu.com/checkout/xxxxx
REVENIU_LINK_ENTERPRISE_MONTHLY=https://app.reveniu.com/checkout/xxxxx

# =============================================
# CONFIGURACIÓN EN VERCEL (producción)
# =============================================
# 1. Ir a Vercel Dashboard → Tu Proyecto → Settings → Environment Variables
# 2. Agregar TODAS las variables de arriba (excepto REVENIU_LINK_*)
# 3. Marcar como "Sensitive": SUPABASE_SERVICE_KEY, DLOCALGO_SECRET_KEY, DLOCALGO_WEBHOOK_SECRET
# 4. Cambiar DLOCALGO_BASE_URL a https://api.dlocalgo.com/v1 para producción
# 5. Cambiar SITE_URL a tu dominio de producción
