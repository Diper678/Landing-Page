# ── Convex ──
# Obtener al ejecutar: npx convex dev
CONVEX_URL=https://your-project.convex.cloud

# ── Clerk (Auth Provider) ──
# Obtener desde: https://dashboard.clerk.com → API Keys / Integrations
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev

# ── App ──
SITE_URL=http://localhost:3000

# ── Resend (Email) ──
RESEND_API_KEY=re_...
FROM_EMAIL=Sisteco <noreply@onboarding.sisteco.cl>

# ── Upstash Redis (Rate Limiting — opcional) ──
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ── n8n ──
N8N_WEBHOOK_URL=https://tu-instancia.n8n.cloud/webhook/sisteco-orchestration
N8N_AUTH_KEY=your_key

# ── Vercel Cron ──
CRON_SECRET=your_cron_secret

# =============================================
# PASARELAS DE PAGO
# =============================================
# Sisteco soporta tres pasarelas:
#   - Flow.cl     → cliente chileno (tarjetas chilenas, transferencia, Webpay)
#   - dLocal Go   → cliente internacional (tarjetas Visa/Mastercard/Amex)
#   - Reveniu     → cliente chileno alternativo (suscripciones recurrentes)
# Planes activos (2026-04-23): junior · senior · manager
# Planes deprecados (NO usar): base, growth, enterprise

# ── Flow.cl (Chile — pasarela principal) ──
# Dashboard: https://www.flow.cl/app
# Documentación: https://www.flow.cl/docs/api.html
# IMPORTANT:
#   1. Las keys NUNCA van en código ni se comitean en git.
#   2. En producción se configuran como Vercel Env Vars marcadas "Sensitive".
#   3. Si una key se expone (chat, screenshot, repo público): rotarla INMEDIATAMENTE en Flow.cl.
FLOW_API_KEY=your_flow_api_key_here
FLOW_SECRET_KEY=your_flow_secret_key_here
FLOW_BASE_URL=https://sandbox.flow.cl/api
# Producción: https://www.flow.cl/api

# Flow.cl URLs de retorno (configuradas en panel Flow + en API calls)
FLOW_RETURN_URL=https://sisteco.cl/pago-exitoso
FLOW_CONFIRMATION_URL=https://sisteco.cl/api/flow-webhook
FLOW_FAILURE_URL=https://sisteco.cl/pago-fallido

# Flow.cl planes / commerceOrder IDs (1 link de pago por combinación plan × cadencia × descuento)
# Pricing en CLP recalculado al valor UF del día. Ver docs/research/2026-04-23-pricing-final-formalizado.md
FLOW_PLAN_JUNIOR_TRIM1=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_JUNIOR_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_JUNIOR_ANUAL=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_SENIOR_TRIM1=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_SENIOR_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_SENIOR_ANUAL=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_MANAGER_TRIM1=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_MANAGER_REGULAR=https://www.flow.cl/btn.php?token=xxxxx
FLOW_PLAN_MANAGER_ANUAL=https://www.flow.cl/btn.php?token=xxxxx

# ── dLocal Go (LATAM internacional) ──
# Dashboard: https://dashboard.dlocalgo.com (prod) / https://dashboard-sbx.dlocalgo.com (sandbox)
DLOCALGO_API_KEY=your_api_key_here
DLOCALGO_SECRET_KEY=your_secret_key_here
DLOCALGO_WEBHOOK_SECRET=your_webhook_secret_here
DLOCALGO_BASE_URL=https://api-sbx.dlocalgo.com/v1

# Plan IDs (nomenclatura nueva)
DLOCALGO_PLAN_JUNIOR_MONTHLY=plan_xxxxx
DLOCALGO_PLAN_JUNIOR_ANNUAL=plan_xxxxx
DLOCALGO_PLAN_SENIOR_MONTHLY=plan_xxxxx
DLOCALGO_PLAN_SENIOR_ANNUAL=plan_xxxxx
DLOCALGO_PLAN_MANAGER_MONTHLY=plan_xxxxx

# ── Reveniu (Chile — alternativa) ──
REVENIU_LINK_JUNIOR_MONTHLY=https://app.reveniu.com/checkout/xxxxx
REVENIU_LINK_JUNIOR_ANNUAL=https://app.reveniu.com/checkout/xxxxx
REVENIU_LINK_SENIOR_MONTHLY=https://app.reveniu.com/checkout/xxxxx
REVENIU_LINK_SENIOR_ANNUAL=https://app.reveniu.com/checkout/xxxxx
REVENIU_LINK_MANAGER_MONTHLY=https://app.reveniu.com/checkout/xxxxx

# =============================================
# CONFIGURACIÓN EN VERCEL (producción)
# =============================================
# 1. Vercel Dashboard → Tu Proyecto → Settings → Environment Variables
# 2. Agregar TODAS las variables de arriba
# 3. Marcar como "Sensitive":
#    - FLOW_API_KEY, FLOW_SECRET_KEY
#    - DLOCALGO_SECRET_KEY, DLOCALGO_WEBHOOK_SECRET
#    - CRON_SECRET, RESEND_API_KEY, N8N_AUTH_KEY
# 4. URLs producción:
#    - FLOW_BASE_URL → https://www.flow.cl/api
#    - DLOCALGO_BASE_URL → https://api.dlocalgo.com/v1
#    - SITE_URL → https://sisteco.cl
# 5. Política de rotación: rotar keys cada 90 días o si hay sospecha de exposición.
